# Required
GEMINI_API_KEY=your_gemini_api_key
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require
QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
REDIS_URL=rediss://:<password>@<host>:6379

# Recommended defaults
QA_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/text-embedding-004
QDRANT_COLLECTION=policy_chunks

# Auth0
AUTH0_ENABLED=true
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_spa_client_id
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_SCOPE=openid profile email
AUTH0_CACHE_LOCATION=localstorage
AUTH0_USE_REFRESH_TOKENS=true

# Optional
AUTH0_ISSUER=
AUTH0_ADMIN_SCOPE=admin:write
AUTH0_JWKS_CACHE_TTL_SECONDS=3600
ELEVENLABS_API_KEY=
