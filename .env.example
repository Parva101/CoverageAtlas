# AI provider
# Use Vertex by default; fallback to Gemini API key when disabled.
AI_USE_VERTEX=1
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=C:\\path\\to\\service-account.json

# Gemini / Vertex keys (optional depending on provider mode)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=
VERTEX_API_KEY=
GEMINI_PROVIDER=
GOOGLE_GENAI_USE_VERTEXAI=false

# Model settings
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
QA_MODEL=gemini-2.5-flash
EXTRACT_MODEL=gemini-2.5-flash
QA_TEMPERATURE=0.2
QA_MAX_OUTPUT_TOKENS=2048

# Source scan controls (used by backend run_source_scan_job)
SOURCE_SCAN_MAX_NEW_DOCS=20
SOURCE_SCAN_MAX_PER_PAYER=0
SOURCE_SCAN_DELAY=1.0
SOURCE_SCAN_USE_VERTEX=1
SOURCE_SCAN_EXTRACT_MODEL=gemini-3-flash-preview

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/coverageatlas

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=policy_chunks

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Auth0 (optional)
# Set AUTH0_ENABLED=true to enforce JWT validation.
# If AUTH0_ENABLED is not set, auth auto-enables only when both
# AUTH0_DOMAIN and AUTH0_AUDIENCE are present.
AUTH0_ENABLED=
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_spa_client_id
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_ISSUER=
AUTH0_ADMIN_SCOPE=admin:write
AUTH0_JWKS_CACHE_TTL_SECONDS=3600
AUTH0_ALLOW_DEV_BYPASS=1
AUTH0_DEV_SUB=dev-user
AUTH0_SCOPE=openid profile email
AUTH0_REDIRECT_URI=
AUTH0_CACHE_LOCATION=localstorage
AUTH0_USE_REFRESH_TOKENS=true

# LiveKit worker
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
AGENT_NAME=Policy_Agent
VOICE_DEFAULT_ROOM=policy-playground-room

# Voice model runtime
GOOGLE_REALTIME_MODEL=gemini-live-2.5-flash-native-audio
GOOGLE_REALTIME_VOICE=Puck
GOOGLE_REALTIME_TEMPERATURE=0.5
GOOGLE_REALTIME_VERTEXAI=1
COVERAGE_API_BASE_URL=http://127.0.0.1:8000
COVERAGE_API_TIMEOUT_SEC=30

# Optional TTS provider
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Frontend local dev only (if you run `npm run dev` in frontend/)
VITE_API_BASE=/api/v1
VITE_AUTH0_ENABLED=true
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id
VITE_AUTH0_AUDIENCE=https://your-api-identifier
VITE_AUTH0_SCOPE=openid profile email
VITE_AUTH0_REDIRECT_URI=
VITE_AUTH0_CACHE_LOCATION=localstorage
VITE_AUTH0_USE_REFRESH_TOKENS=true
VITE_TWILIO_NUMBER=+16026100653
