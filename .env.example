# Gemini (required)
GEMINI_API_KEY=your_gemini_api_key_here
# For Vertex mode, set GEMINI_PROVIDER=vertex (or GOOGLE_GENAI_USE_VERTEXAI=true)
# and provide GOOGLE_CLOUD_PROJECT + GOOGLE_CLOUD_LOCATION + VERTEX_API_KEY.
GOOGLE_API_KEY=
VERTEX_API_KEY=
GEMINI_PROVIDER=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
EMBEDDING_MODEL=models/text-embedding-004
QA_MODEL=gemini-1.5-pro

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/coverageatlas
# Neon cloud example:
# DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=policy_chunks

# Redis / Celery
REDIS_URL=redis://redis:6379/0
# Upstash cloud example:
# REDIS_URL=rediss://:<password>@<host>:6379

# Auth0 (optional)
# Set AUTH0_ENABLED=true to enforce JWT validation.
# If AUTH0_ENABLED is not set, auth auto-enables only when both
# AUTH0_DOMAIN and AUTH0_AUDIENCE are present.
AUTH0_ENABLED=
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_spa_client_id
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_ISSUER=
AUTH0_ADMIN_SCOPE=admin:write
AUTH0_JWKS_CACHE_TTL_SECONDS=3600
AUTH0_SCOPE=openid profile email
AUTH0_REDIRECT_URI=
AUTH0_CACHE_LOCATION=localstorage
AUTH0_USE_REFRESH_TOKENS=true

# ElevenLabs (optional ? for voice TTS/STT)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Frontend local dev only (if you run `npm run dev` in frontend/)
VITE_API_BASE=/api/v1
# Vercel production example:
# VITE_API_BASE=https://<your-render-service>.onrender.com/api/v1
VITE_AUTH0_ENABLED=true
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id
VITE_AUTH0_AUDIENCE=https://your-api-identifier
VITE_AUTH0_SCOPE=openid profile email
VITE_AUTH0_REDIRECT_URI=
VITE_AUTH0_CACHE_LOCATION=localstorage
VITE_AUTH0_USE_REFRESH_TOKENS=true
