# ── Gemini (required) ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
EMBEDDING_MODEL=models/text-embedding-004
QA_MODEL=gemini-1.5-pro

# ── PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/coverageatlas

# ── Qdrant ─────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=policy_chunks

# ── Redis / Celery ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth0 (optional — leave blank to disable JWT enforcement) ──────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_JWKS_CACHE_TTL_SECONDS=3600

# ── ElevenLabs (optional — for voice TTS/STT) ─────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
